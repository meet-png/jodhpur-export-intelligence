# Jodhpur Export Intelligence System — environment template
# Copy this file to `.env` and fill in your real credentials.
# `.env` is gitignored. NEVER commit real keys.

# --- UN Comtrade Plus API ---
# Get from https://comtradeplus.un.org → API Management → My Subscriptions
COMTRADE_API_KEY=your_comtrade_subscription_key_here

# --- Supabase Postgres ---
# Get from Supabase project → Settings → Database → Connection string (URI)
# Use the POOLER (port 6543) for serverless / GitHub Actions friendly connections
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# --- Email alerts (Phase 7: GitHub Actions failure notifications) ---
# Create a Gmail App Password: https://myaccount.google.com/apppasswords
# (requires 2FA enabled on your Google account)
ALERT_EMAIL_FROM=your_alert_email@gmail.com
ALERT_EMAIL_PASSWORD=your_16_char_app_password
ALERT_EMAIL_TO=meetkabra149@gmail.com

# --- Optional: data sample size override ---
# Useful for development; in production set to 0 (no limit)
COMTRADE_MAX_ROWS=0

# --- Run mode ---
# 'dev' uses smaller batches and verbose logging; 'prod' is silent + full pull
RUN_MODE=dev
